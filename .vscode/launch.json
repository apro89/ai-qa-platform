{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Playwright Tests",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@qa/automation", "exec", "playwright", "test", "--debug"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/apps/automation"
    },
    {
      "name": "Debug AI Platform API",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@qa/ai-platform", "exec", "tsx", "api/server.ts"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/apps/ai-platform",
      "envFile": "${workspaceFolder}/.env"
    }
  ]
}
