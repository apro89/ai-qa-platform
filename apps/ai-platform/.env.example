# LLM Provider Configuration
# Copy this file to .env and update with your settings
# DO NOT commit .env to version control!

# ============================================
# OPTION 1: Use Ollama (Local, Free)
# ============================================
# Uncomment this section to use Ollama

LLM_PROVIDER=ollama
OLLAMA_MODEL=mistral
OLLAMA_BASE_URL=http://localhost:11434

# Available Ollama models:
# - mistral (fast, recommended)
# - llama2 (Meta's LLaMA 2)
# - neural-chat (Intel's chat model)
# - dolphin-mixtral (powerful mixture)
# - orca-mini (smaller, faster)

# ============================================
# OPTION 2: Use OpenAI (Cloud-Based)
# ============================================
# Uncomment this section to use OpenAI
# Get your API key from: https://platform.openai.com/account/api-keys

# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-actual-key-here
# OPENAI_MODEL=gpt-4o

# Available OpenAI models:
# - gpt-4o (latest, most capable)
# - gpt-4 (previous version)
# - gpt-3.5-turbo (faster, cheaper)

# ============================================
# Common Configuration
# ============================================

# Temperature: Controls randomness (0.0 = deterministic, 1.0 = creative)
# TEMPERATURE=0.7

# Max tokens: Maximum length of generated response
# MAX_TOKENS=1024

# Timeout: Request timeout in milliseconds
# TIMEOUT=30000
