{
  "name": "ai-qa-platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm --filter @qa/automation test",
    "test:smoke": "pnpm --filter @qa/automation test:smoke",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev:platform": "pnpm --filter @qa/ai-platform dev",
    "dev:dashboard": "pnpm --filter @qa/dashboard dev"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "eslint": "^9.16.0",
    "globals": "^15.0.0",
    "prettier": "^3.5.3",
    "typescript-eslint": "^8.15.0"
  }
}
